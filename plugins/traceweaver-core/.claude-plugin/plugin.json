{
  "name": "traceweaver-core",
  "version": "0.1.0-alpha.0",
  "description": "Systems-engineering authority control and advisory automation for agentic software work.",
  "author": {
    "name": "Oxiom Systems",
    "url": "https://github.com/Oxiom-Systems"
  },
  "homepage": "https://github.com/Oxiom-Systems/traceweaver",
  "repository": "https://github.com/Oxiom-Systems/traceweaver",
  "license": "MIT",
  "keywords": [
    "traceweaver",
    "systems-engineering",
    "requirements",
    "traceability",
    "agentic-workflow",
    "compound-engineering"
  ],
  "modelDefaults": {
    "claude": {
      "model": "sonnet",
      "enforcement": "policy_recorded_runtime_enforcement_held"
    },
    "codex": {
      "model": "gpt-5.5",
      "reasoningEffort": "medium",
      "enforcement": "policy_recorded_for_codex_packaging"
    },
    "importedCeComponentBodyPolicy": "no_model_default_edits_without_reviewed_overlay_fork_record"
  },
  "traceweaver": {
    "anchor": "TRACEWEAVER: file-role=model-default-claude-plugin-manifest; req=REQ-TW-060; trace=TRACE-TW-043; ver=VER-TW-055"
  },
  "skills": "./skills"
}
