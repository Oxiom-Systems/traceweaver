#!/usr/bin/env bash

set -e

if [ $# -eq 0 ]; then
    echo "Usage: resolve-pr-thread THREAD_ID"
    echo "Example: resolve-pr-thread PRRT_kwDOABC123"
    exit 1
fi

THREAD_ID=$1

echo "TraceWeaver alpha publication hold: would resolve review thread $THREAD_ID" >&2
echo "No TraceWeaver publication gate is approved for this alpha package; this script is draft-only." >&2
exit 2
