#!/usr/bin/env bash
# TRACEWEAVER: file-role=separate-home-runtime-smoke; verifies=VER-TW-025; req=REQ-TW-016; trace=TRACE-TW-016; ver=VER-TW-025
# TRACEWEAVER: file-role=model-default-separate-home-runtime-smoke; req=REQ-TW-060; trace=TRACE-TW-043; ver=VER-TW-055
# TRACEWEAVER: verifies=VER-TW-055; req=REQ-TW-060; trace=TRACE-TW-043
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmp_home="$(mktemp -d /tmp/traceweaver-u9-separate-home.XXXXXX)"
codex_home="$tmp_home/.codex"
expected_codex_model="gpt-5.5"
expected_codex_reasoning_effort="medium"
expected_claude_model="sonnet"
model="${TRACEWEAVER_CODEX_MODEL:-gpt-5.5}"
reasoning_effort="${TRACEWEAVER_CODEX_REASONING_EFFORT:-medium}"
exec_timeout_seconds="${TRACEWEAVER_CODEX_EXEC_TIMEOUT_SECONDS:-120}"
auth_mode="${TRACEWEAVER_CODEX_AUTH_MODE:-none}"
auth_copy="$codex_home/auth.json"
auth_copy_used=false
auth_copy_requested=false

mkdir -p "$codex_home"

cleanup_auth_copy() {
  rm -f "$auth_copy"
}

trap cleanup_auth_copy EXIT

case "$auth_mode" in
  none)
    ;;
  copy)
    auth_copy_requested=true
    if [ -f "$HOME/.codex/auth.json" ]; then
      cp "$HOME/.codex/auth.json" "$auth_copy"
      auth_copy_used=true
    fi
    ;;
  *)
    echo "fresh_codex_auth_mode_error=unsupported_auth_mode_$auth_mode" >&2
    exit 2
    ;;
esac

prompt="$tmp_home/prompt.txt"
last_message="$tmp_home/last-message.txt"
events="$tmp_home/exec-events.jsonl"
stderr_log="$tmp_home/exec.err"
install_log="$tmp_home/install.out"
prompt_input="$tmp_home/prompt-input.json"
visible_skills="$tmp_home/visible-skills.txt"
required_visible_skills=(
  tw-auto
  lfg
  tw-authority-gate
  tw-traceability-check
  tw-requirements-review
  tw-code-review
  tw-doc-review
  tw-grill
)

json_query() {
  python3 - "$1" "$2" <<'PY'
import json
import sys

path = sys.argv[1]
query = sys.argv[2].split(".")
with open(path, "r", encoding="utf-8") as handle:
    value = json.load(handle)
for part in query:
    value = value[part]
print(value)
PY
}

cat >"$prompt" <<'EOF'
Use the tw-authority-gate skill. You may run read-only shell commands only to
open or hash the installed skill file named in the available-skills list. Do not
edit files.

Reply exactly in this format and nothing else, replacing HASH with the SHA-256
of the installed tw-authority-gate SKILL.md file you inspected:

TRACEWEAVER_SKILL_HASH=HASH

If the skill is unavailable, not listed, not loaded, or cannot be used, reply
exactly with this one line and nothing else:

TRACEWEAVER_SKILL_HELD=not_available
EOF

bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$tmp_home" >"$install_log"

manifest="$codex_home/traceweaver-core/install-manifest.json"
expected_skill_hash="$(shasum -a 256 "$codex_home/skills/tw-authority-gate/SKILL.md" | awk '{print $1}')"
HOME="$tmp_home" CODEX_HOME="$codex_home" codex debug prompt-input \
  "Use TraceWeaver required direct skills: tw-authority-gate tw-auto lfg tw-traceability-check tw-requirements-review tw-code-review tw-doc-review tw-grill." >"$prompt_input"
jq -r '.. | strings' "$prompt_input" | perl -ne 'print "$1\n" if /^- ([A-Za-z0-9_.:-]+): /' >"$visible_skills"

missing_visible_skills=()
for skill_name in "${required_visible_skills[@]}"; do
  if ! grep -qx "$skill_name" "$visible_skills"; then
    missing_visible_skills+=("$skill_name")
  fi
done

set +e
HOME="$tmp_home" CODEX_HOME="$codex_home" perl -e 'alarm shift; exec @ARGV' "$exec_timeout_seconds" codex exec \
  --ignore-user-config \
  -m "$model" \
  -c "model_reasoning_effort=\"$reasoning_effort\"" \
  --sandbox read-only \
  --skip-git-repo-check \
  --ignore-rules \
  --output-last-message "$last_message" \
  --json <"$prompt" >"$events" 2>"$stderr_log"
exec_status=$?
set -e

cleanup_auth_copy

message="$(cat "$last_message" 2>/dev/null || true)"
normalized_message="$(printf '%s' "$message" | tr -d '\r' | sed -e 's/[[:space:]]*$//')"

echo "separate_codex_home=$tmp_home"
echo "separate_codex_dot_home=$codex_home"
echo "separate_home_install_log=$install_log"
echo "separate_home_exec_events=$events"
echo "separate_home_exec_stderr=$stderr_log"
echo "separate_home_exec_last_message=$last_message"
echo "separate_home_prompt_input=$prompt_input"
echo "separate_home_visible_skills=$visible_skills"
echo "separate_home_install_result=pass"
echo "separate_home_runtime_home_isolated=true"
echo "fresh_codex_auth_mode=$auth_mode"
echo "fresh_codex_runtime_model=$model"
echo "fresh_codex_runtime_reasoning_effort=$reasoning_effort"
echo "fresh_codex_model_default_policy_codex_model=$(json_query "$manifest" modelDefaults.codex.model)"
echo "fresh_codex_model_default_policy_codex_reasoning_effort=$(json_query "$manifest" modelDefaults.codex.reasoningEffort)"
echo "fresh_codex_model_default_policy_claude_model=$(json_query "$manifest" modelDefaults.claude.model)"
if [ "$(json_query "$manifest" modelDefaults.codex.model)" = "$expected_codex_model" ] \
  && [ "$(json_query "$manifest" modelDefaults.codex.reasoningEffort)" = "$expected_codex_reasoning_effort" ] \
  && [ "$(json_query "$manifest" modelDefaults.claude.model)" = "$expected_claude_model" ]; then
  echo "fresh_codex_model_default_manifest=pass"
else
  echo "fresh_codex_model_default_manifest=held_mismatch"
fi
if [ "$model" = "$expected_codex_model" ] && [ "$reasoning_effort" = "$expected_codex_reasoning_effort" ]; then
  echo "fresh_codex_runtime_model_default_match=pass_default_runtime_args"
else
  echo "fresh_codex_runtime_model_default_match=pass_explicit_override_runtime_args"
fi
if [ "$auth_copy_used" = true ]; then
  echo "fresh_codex_auth_boundary=held_live_auth_copy_available_to_read_only_exec_until_tokenless_probe_exists"
elif [ "$auth_copy_requested" = true ]; then
  echo "fresh_codex_auth_boundary=held_auth_copy_requested_but_source_missing"
else
  echo "fresh_codex_auth_boundary=pass_no_auth_copy_used"
fi
if [ -f "$auth_copy" ]; then
  echo "fresh_codex_retained_auth_copy_present=true"
else
  echo "fresh_codex_retained_auth_copy_present=false"
fi
echo "fresh_codex_invocation_target=tw-authority-gate"
echo "fresh_codex_expected_skill_hash=$expected_skill_hash"
echo "fresh_codex_exec_exit_code=$exec_status"
echo "fresh_codex_tw_authority_gate_visible=$(grep -qx 'tw-authority-gate' "$visible_skills" && echo true || echo false)"
if find "$codex_home/skills" -maxdepth 1 -mindepth 1 -type d -name 'ce-*' -print -quit | grep -q .; then
  echo "fresh_codex_ce_derived_direct_callable_surface=failed"
  exit 1
else
  echo "fresh_codex_ce_derived_direct_callable_surface=absent"
fi
if [ "${#missing_visible_skills[@]}" -eq 0 ]; then
  echo "fresh_codex_required_skills_visible=true"
else
  echo "fresh_codex_required_skills_visible=false"
  echo "fresh_codex_missing_required_visible_skills=${missing_visible_skills[*]}"
fi

if [ "${#missing_visible_skills[@]}" -ne 0 ]; then
  echo "fresh_codex_reload_probe=held_skill_registry_visible_list_excludes_required_traceweaver_skills"
  echo "fresh_codex_runtime_skill_invocation=held_skill_registry_visible_list_excludes_required_traceweaver_skills"
  echo "fresh_codex_registry_loading_observation=held_required_traceweaver_skills_not_in_visible_skill_list"
  exit 0
fi

if [ "$exec_status" -ne 0 ]; then
  if [ "$auth_copy_used" = false ] && grep -Eiq "(401 Unauthorized|Missing bearer|authentication required|Unauthorized)" "$stderr_log"; then
    echo "fresh_codex_reload_probe=held_codex_exec_auth_required_without_credential_copy"
    echo "fresh_codex_runtime_skill_invocation=held_no_runtime_invocation_without_auth_in_isolated_codex_home"
    echo "fresh_codex_auth_safe_runtime_observation=skills_visible_but_codex_exec_requires_auth_in_isolated_home"
  else
    echo "fresh_codex_reload_probe=held_codex_exec_failed"
    echo "fresh_codex_runtime_skill_invocation=held_codex_exec_failed"
  fi
  exit 0
fi

if [ "$normalized_message" = "TRACEWEAVER_SKILL_HELD=not_available" ] || printf '%s' "$message" | grep -Eiq "(available skills list|current skill list|current skills list|installed skill list).*(does not include|for this session|not present|isn.?t available)|not present in the current skill list|not available in this session|isn.?t available in this session|unavailable|not loaded|cannot load|can.?t load|could not load|couldn.?t load|not found|no such skill"; then
  echo "fresh_codex_reload_probe=held_skill_not_visible_in_fresh_exec_registry"
  echo "fresh_codex_runtime_skill_invocation=held_skill_not_visible_in_fresh_exec_registry"
  exit 0
fi

if [ "$normalized_message" = "TRACEWEAVER_SKILL_HASH=$expected_skill_hash" ] && [ "$auth_copy_used" = true ]; then
  echo "fresh_codex_reload_probe=held_auth_boundary_after_skill_hash_sentinel"
  echo "fresh_codex_runtime_skill_invocation=held_live_auth_copy_boundary"
  exit 0
fi

if [ "$normalized_message" = "TRACEWEAVER_SKILL_HASH=$expected_skill_hash" ]; then
  echo "fresh_codex_reload_probe=pass_skill_visible_in_fresh_exec_registry"
  echo "fresh_codex_runtime_skill_invocation=pass_tw_authority_gate_skill_file_read"
  exit 0
fi

echo "fresh_codex_reload_probe=held_unclassified_exec_transcript"
echo "fresh_codex_runtime_skill_invocation=held_unclassified_exec_transcript"
