#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"

inventory_path = ARGV[0] || "docs/validation/traceweaver-core-11-ce-runtime-inventory.md"
plugin_root = ARGV[1] || "plugins/traceweaver-core"
repo_root = File.expand_path(File.join(plugin_root, "..", ".."))
controlled_autonomy_evidence_path = File.join(repo_root, "docs/validation/traceweaver-controlled-autonomy-alpha.md")

inventory = File.read(inventory_path)
selected = inventory.scan(/`((?:skills|agents)\/[^`]+)` \| `([0-9a-f]{64})` \| selected (?:skill|agent) file/).to_h
abort "Controlled-autonomy evidence not found: #{controlled_autonomy_evidence_path}" unless File.file?(controlled_autonomy_evidence_path)

controlled_autonomy_evidence = File.read(controlled_autonomy_evidence_path)
controlled_autonomy_hashes = controlled_autonomy_evidence.scan(/\| `([^`]+)` \| `([0-9a-f]{64})` \|/).to_h

abort "No selected CE files found in #{inventory_path}" if selected.empty?

packaged_patterns = [
  "skills/ce-*",
  "skills/lfg",
  "agents/ce-*"
]

required_traceweaver_files = [
  "skills/tw-authority-gate/SKILL.md",
  "skills/tw-auto/SKILL.md",
  "skills/tw-auto/references/automation-loop-state-template.yml",
  "skills/tw-auto/references/intent-contract-template.yml",
  "skills/tw-auto/references/requirements-baseline-template.md",
  "skills/tw-auto/references/traceability-matrix-bootstrap-template.md",
  "skills/tw-auto/references/traceweaver-controlled-autonomy-policy.md",
  "skills/tw-grill/SKILL.md",
  "skills/tw-grill/references/upstream-notice.md",
  "skills/tw-requirements-review/SKILL.md",
  "skills/tw-traceability-check/SKILL.md",
  "skills/requirements-reviewer/SKILL.md",
  "skills/systems-engineering-traceability/SKILL.md",
  "skills/using-agent-skills/SKILL.md",
  "references/authority-baseline-template.yml",
  "references/automation-loop-state-template.yml",
  "references/change-template.yml",
  "references/exception-template.yml",
  "references/gap-template.yml",
  "references/intent-contract-template.yml",
  "references/requirements-and-vv-guide.md",
  "references/requirements-baseline-template.md",
  "references/risk-gap-and-change-control-guide.md",
  "references/systems-engineering-traceability-operating-model.md",
  "references/task-capsule-template.yml",
  "references/trace-record-template.yml",
  "references/traceability-matrix-bootstrap-template.md",
  "references/traceability-matrix-template.md",
  "references/traceweaver-controlled-autonomy-policy.md",
  "references/traceweaver-runtime-policy.md"
]

packaged = packaged_patterns.flat_map do |pattern|
  Dir.glob(File.join(plugin_root, pattern)).flat_map do |entry|
    if File.file?(entry)
      [entry]
    else
      Dir.glob(File.join(entry, "**", "*"))
    end
  end
end
  .select { |path| File.file?(path) }
  .map { |path| path.delete_prefix("#{plugin_root}/") }
  .uniq

missing = selected.keys.reject { |path| File.file?(File.join(plugin_root, path)) }
extra = packaged.reject { |path| selected.key?(path) }
missing_traceweaver = required_traceweaver_files.reject { |path| File.file?(File.join(plugin_root, path)) }
required_traceweaver_hash_paths = required_traceweaver_files.map { |path| "plugins/traceweaver-core/#{path}" } + [
  "src/index.ts",
  "README.md",
  "traceability-matrix.md"
]
evidence_hash_paths = controlled_autonomy_hashes.keys.select do |path|
  File.file?(File.join(repo_root, path))
end
traceweaver_hash_paths = (required_traceweaver_hash_paths + evidence_hash_paths).uniq
missing_traceweaver_hash_records = required_traceweaver_hash_paths.reject do |path|
  controlled_autonomy_hashes.key?(path)
end
hash_mismatches = selected.each_with_object([]) do |(path, expected), records|
  full = File.join(plugin_root, path)
  next records unless File.file?(full)

  actual = Digest::SHA256.file(full).hexdigest
  records << [path, expected, actual] unless actual == expected
end
traceweaver_hash_mismatches = traceweaver_hash_paths.each_with_object([]) do |path, records|
  expected = controlled_autonomy_hashes[path]
  next records unless expected

  full = File.join(repo_root, path)
  next records unless File.file?(full)

  actual = Digest::SHA256.file(full).hexdigest
  records << [path, expected, actual] unless actual == expected
end

puts "selected_files=#{selected.size}"
puts "packaged_ce_files=#{packaged.size}"
puts "missing=#{missing.empty? ? 'none' : missing.join(',')}"
puts "extra=#{extra.empty? ? 'none' : extra.join(',')}"
puts "traceweaver_required_files=#{required_traceweaver_files.size}"
puts "traceweaver_missing=#{missing_traceweaver.empty? ? 'none' : missing_traceweaver.join(',')}"
puts "traceweaver_missing_hash_records=#{missing_traceweaver_hash_records.empty? ? 'none' : missing_traceweaver_hash_records.join(',')}"
puts "hash_mismatches=#{hash_mismatches.empty? ? 'none' : hash_mismatches.map { |path, expected, actual| "#{path}:#{expected}:#{actual}" }.join(',')}"
puts "traceweaver_hash_mismatches=#{traceweaver_hash_mismatches.empty? ? 'none' : traceweaver_hash_mismatches.map { |path, expected, actual| "#{path}:#{expected}:#{actual}" }.join(',')}"

exit 1 unless missing.empty? && extra.empty? && missing_traceweaver.empty? && missing_traceweaver_hash_records.empty? && hash_mismatches.empty? && traceweaver_hash_mismatches.empty?
