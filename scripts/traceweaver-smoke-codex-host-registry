#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
codex_home="${CODEX_HOME:-$HOME/.codex}"
skills_root="$codex_home/skills"

hash_file() {
  shasum -a 256 "$1" | awk '{print $1}'
}

required_direct_skills=(
  tw-auto
  lfg
  tw-authority-gate
  tw-traceability-check
  tw-requirements-review
  tw-grill
  ce-plan
  ce-work
  ce-code-review
  ce-doc-review
)

traceweaver_native_skills=(
  tw-auto
  tw-authority-gate
  tw-traceability-check
  tw-requirements-review
  tw-grill
)

missing=()
stale=()
unmarked=()
present=()

for skill_name in "${required_direct_skills[@]}"; do
  source_skill="$repo_root/plugins/traceweaver-core/skills/$skill_name/SKILL.md"
  host_skill="$skills_root/$skill_name/SKILL.md"
  marker="$skills_root/$skill_name/.traceweaver-core-install.json"

  if [ ! -f "$host_skill" ]; then
    missing+=("$skill_name")
    continue
  fi

  present+=("$skill_name")

  if [ ! -f "$marker" ]; then
    unmarked+=("$skill_name")
  fi

  if [ -f "$source_skill" ]; then
    source_hash="$(hash_file "$source_skill")"
    host_hash="$(hash_file "$host_skill")"
    if [ "$source_hash" != "$host_hash" ]; then
      stale+=("$skill_name")
    fi
  fi
done

native_missing=()
for skill_name in "${traceweaver_native_skills[@]}"; do
  if [ ! -f "$skills_root/$skill_name/SKILL.md" ]; then
    native_missing+=("$skill_name")
  fi
done

echo "codex_host_skills_root=$skills_root"
echo "codex_host_required_skills=${required_direct_skills[*]}"
echo "codex_host_present_skills=${present[*]:-none}"
echo "codex_host_missing_skills=${missing[*]:-none}"
echo "codex_host_unmarked_skills=${unmarked[*]:-none}"
echo "codex_host_stale_skills=${stale[*]:-none}"

if [ "${#native_missing[@]}" -gt 0 ]; then
  echo "codex_host_traceweaver_native_missing=${native_missing[*]}"
fi

if [ "${#missing[@]}" -eq 0 ] && [ "${#stale[@]}" -eq 0 ] && [ "${#unmarked[@]}" -eq 0 ]; then
  echo "codex_host_registry_filesystem_probe=pass_traceweaver_direct_callable_files_present"
  echo "host_codex_registry_discovery=held_active_session_callable_registry_not_proven"
else
  echo "codex_host_registry_filesystem_probe=held_missing_or_untrusted_direct_callable_files"
  echo "host_codex_registry_discovery=held_missing_traceweaver_direct_callable_host_install_or_active_registry_reload"
fi

echo "real_tw_skill_runtime_invocation=held_no_host_transcript_or_runner"
