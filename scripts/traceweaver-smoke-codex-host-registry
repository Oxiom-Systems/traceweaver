#!/usr/bin/env bash
set -euo pipefail

# TRACEWEAVER: file-role=host-registry-smoke; req=REQ-TW-052; trace=TRACE-TW-037; ver=VER-TW-047
# TRACEWEAVER: verifies=VER-TW-047; req=REQ-TW-052; trace=TRACE-TW-037
# TRACEWEAVER: file-role=host-registry-smoke; req=REQ-TW-057; trace=TRACE-TW-032; ver=VER-TW-041
# TRACEWEAVER: verifies=VER-TW-041; req=REQ-TW-057; trace=TRACE-TW-032
# TRACEWEAVER: file-role=model-default-host-registry-smoke; req=REQ-TW-060; trace=TRACE-TW-043; ver=VER-TW-055
# TRACEWEAVER: verifies=VER-TW-055; req=REQ-TW-060; trace=TRACE-TW-043
# TRACEWEAVER: file-role=audit-wrapper-host-runtime-smoke; req=REQ-TW-061; trace=TRACE-TW-052; ver=VER-TW-065
# TRACEWEAVER: verifies=VER-TW-065; req=REQ-TW-061; trace=TRACE-TW-052
# TRACEWEAVER: file-role=requirements-quality-active-host-smoke; req=REQ-TW-069; trace=TRACE-TW-055; ver=VER-TW-071
# TRACEWEAVER: verifies=VER-TW-071; req=REQ-TW-069; trace=TRACE-TW-055
# TRACEWEAVER: file-role=requirements-quality-runtime-output-smoke; req=REQ-TW-069; trace=TRACE-TW-055; ver=VER-TW-072
# TRACEWEAVER: verifies=VER-TW-072; req=REQ-TW-069; trace=TRACE-TW-055

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
codex_home="${CODEX_HOME:-$HOME/.codex}"
skills_root="$codex_home/skills"
references_root="$codex_home/traceweaver-core/references"
config_file="$codex_home/config.toml"
expected_codex_model="gpt-5.5"
expected_codex_reasoning_effort="medium"
expected_claude_model="sonnet"
source_model_policy_reference="$repo_root/plugins/traceweaver-core/references/traceweaver-model-defaults.md"
host_model_policy_reference="$references_root/traceweaver-model-defaults.md"
model="${TRACEWEAVER_CODEX_MODEL:-gpt-5.5}"
reasoning_effort="${TRACEWEAVER_CODEX_REASONING_EFFORT:-medium}"
exec_timeout_seconds="${TRACEWEAVER_CODEX_EXEC_TIMEOUT_SECONDS:-60}"
host_runtime_exec="${TRACEWEAVER_HOST_RUNTIME_EXEC:-1}"
host_runtime_skill="${TRACEWEAVER_HOST_RUNTIME_SKILL:-tw-authority-gate}"
host_runtime_proof="${TRACEWEAVER_HOST_RUNTIME_PROOF:-skill-file-read}"

case "$host_runtime_skill" in
  tw-authority-gate|tw-audit|tw-requirements-review)
    ;;
  *)
    echo "unsupported_traceweaver_host_runtime_skill=$host_runtime_skill" >&2
    exit 64
    ;;
esac

case "$host_runtime_proof" in
  skill-file-read)
    ;;
  requirements-review-output)
    if [ "$host_runtime_skill" != "tw-requirements-review" ]; then
      echo "unsupported_traceweaver_host_runtime_proof_target=$host_runtime_skill" >&2
      exit 65
    fi
    ;;
  *)
    echo "unsupported_traceweaver_host_runtime_proof=$host_runtime_proof" >&2
    exit 66
    ;;
esac

hash_file() {
  shasum -a 256 "$1" | awk '{print $1}'
}

compound_engineering_plugin_enabled() {
  if [ ! -f "$config_file" ]; then
    echo "unknown_config_missing"
    return
  fi

  awk '
    $0 == "[plugins.\"compound-engineering@compound-engineering-plugin\"]" {
      in_section = 1
      next
    }
    /^\[/ && in_section {
      in_section = 0
    }
    in_section && $1 == "enabled" {
      gsub(/[[:space:]]/, "", $3)
      print $3
      found = 1
      exit
    }
    END {
      if (!found) print "unknown_setting_missing"
    }
  ' "$config_file"
}

required_direct_skills=(
  tw-auto
  tw-strategy
  tw-ideate
  tw-plan
  tw-brainstorm
  tw-audit
  lfg
  tw-authority-gate
  tw-work
  tw-traceability-check
  tw-requirements-review
  tw-debug
  tw-code-review
  tw-doc-review
  tw-commit
  tw-commit-push-pr
  tw-compound
  tw-compound-refresh
  tw-resolve-pr-feedback
  tw-sessions
  tw-test-browser
  tw-test-xcode
  tw-setup
  tw-worktree
  tw-update
  tw-grill
)

traceweaver_native_skills=(
  tw-auto
  tw-strategy
  tw-ideate
  tw-plan
  tw-brainstorm
  tw-audit
  tw-authority-gate
  tw-work
  tw-traceability-check
  tw-requirements-review
  tw-debug
  tw-code-review
  tw-doc-review
  tw-commit
  tw-commit-push-pr
  tw-compound
  tw-compound-refresh
  tw-resolve-pr-feedback
  tw-sessions
  tw-test-browser
  tw-test-xcode
  tw-setup
  tw-worktree
  tw-update
  tw-grill
)

required_skill_local_files=(
  "tw-traceability-check/references/traceweaver-operating-modes.md"
  "tw-code-review/references/traceweaver-operating-modes.md"
  "tw-doc-review/references/traceweaver-operating-modes.md"
  "tw-auto/references/traceweaver-operating-modes.md"
  "tw-audit/references/traceweaver-operating-modes.md"
  "tw-strategy/references/traceweaver-operating-modes.md"
  "tw-ideate/references/traceweaver-operating-modes.md"
  "tw-plan/references/traceweaver-operating-modes.md"
  "tw-work/references/traceweaver-operating-modes.md"
  "tw-brainstorm/references/traceweaver-operating-modes.md"
  "tw-compound/references/traceweaver-operating-modes.md"
  "tw-compound-refresh/references/traceweaver-operating-modes.md"
  "tw-resolve-pr-feedback/references/traceweaver-operating-modes.md"
  "tw-sessions/references/traceweaver-operating-modes.md"
  "tw-test-browser/references/traceweaver-operating-modes.md"
  "tw-test-xcode/references/traceweaver-operating-modes.md"
  "tw-setup/references/traceweaver-operating-modes.md"
  "tw-worktree/references/traceweaver-operating-modes.md"
  "tw-plan/references/verification-planner-guide.md"
  "tw-plan/references/validation-planner-guide.md"
  "tw-test-browser/references/verification-planner-guide.md"
  "tw-test-xcode/references/verification-planner-guide.md"
  "tw-audit/references/validation-planner-guide.md"
  "tw-audit/references/technical-review-and-audit-gate-guide.md"
  "tw-audit/references/baseline-configuration-control-guide.md"
  "tw-authority-gate/references/baseline-configuration-control-guide.md"
  "tw-brainstorm/references/needs-and-requirements-capture-guide.md"
  "tw-grill/references/needs-and-requirements-capture-guide.md"
  "tw-plan/references/design-decision-reviewer-guide.md"
  "tw-doc-review/references/design-decision-reviewer-guide.md"
  "tw-plan/references/architecture-and-interface-reviewer-guide.md"
  "tw-code-review/references/architecture-and-interface-reviewer-guide.md"
  "tw-traceability-check/references/code-trace-anchor-contract.md"
  "tw-traceability-check/references/trace-anchor-authoring.md"
  "tw-work/references/trace-anchor-authoring.md"
  "tw-code-review/references/trace-anchor-authoring.md"
  "tw-doc-review/references/trace-anchor-authoring.md"
  "tw-auto/references/trace-anchor-authoring.md"
  "tw-traceability-check/scripts/traceweaver-check-code-anchors"
  "tw-traceability-check/scripts/traceweaver-author-code-anchors"
)

missing=()
stale=()
unmarked=()
present=()
missing_skill_local_files=()
stale_skill_local_files=()
ce_direct_callable_skills=()

for skill_name in "${required_direct_skills[@]}"; do
  source_skill="$repo_root/plugins/traceweaver-core/skills/$skill_name/SKILL.md"
  host_skill="$skills_root/$skill_name/SKILL.md"
  marker="$skills_root/$skill_name/.traceweaver-core-install.json"

  if [ ! -f "$host_skill" ]; then
    missing+=("$skill_name")
    continue
  fi

  present+=("$skill_name")

  if [ ! -f "$marker" ]; then
    unmarked+=("$skill_name")
  fi

  if [ -f "$source_skill" ]; then
    source_hash="$(hash_file "$source_skill")"
    host_hash="$(hash_file "$host_skill")"
    if [ "$source_hash" != "$host_hash" ]; then
      stale+=("$skill_name")
    fi
  fi
done

while IFS= read -r ce_skill_dir; do
  [ -n "$ce_skill_dir" ] || continue
  ce_direct_callable_skills+=("$(basename "$ce_skill_dir")")
done < <(find "$skills_root" -maxdepth 1 -mindepth 1 -type d -name 'ce-*' 2>/dev/null | sort)

for skill_local_file in "${required_skill_local_files[@]}"; do
  source_file="$repo_root/plugins/traceweaver-core/skills/$skill_local_file"
  host_file="$skills_root/$skill_local_file"

  if [ ! -f "$host_file" ]; then
    missing_skill_local_files+=("$skill_local_file")
    continue
  fi

  if [ -f "$source_file" ]; then
    source_hash="$(hash_file "$source_file")"
    host_hash="$(hash_file "$host_file")"
    if [ "$source_hash" != "$host_hash" ]; then
      stale_skill_local_files+=("$skill_local_file")
    fi
  fi
done

native_missing=()
for skill_name in "${traceweaver_native_skills[@]}"; do
  if [ ! -f "$skills_root/$skill_name/SKILL.md" ]; then
    native_missing+=("$skill_name")
  fi
done

active_skill_directory_count="$(find "$skills_root" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
ce_plugin_enabled="$(compound_engineering_plugin_enabled)"
source_model_policy_hash=""
host_model_policy_hash=""
if [ -f "$source_model_policy_reference" ]; then
  source_model_policy_hash="$(hash_file "$source_model_policy_reference")"
fi
if [ -f "$host_model_policy_reference" ]; then
  host_model_policy_hash="$(hash_file "$host_model_policy_reference")"
fi

runtime_tmp="$(mktemp -d)"
requirements_review_runtime_prompt="$repo_root/fixtures/tw-skill-behavior/active-host-requirements-review-runtime/prompt.txt"
prompt_input="$runtime_tmp/prompt-input.json"
visible_skills="$runtime_tmp/visible-skills.txt"
prompt="$runtime_tmp/prompt.txt"
last_message="$runtime_tmp/last-message.txt"
events="$runtime_tmp/exec-events.jsonl"
stderr_log="$runtime_tmp/exec.err"
expected_authority_gate_hash=""
expected_runtime_skill_hash=""

cat >"$prompt" <<EOF
Use the $host_runtime_skill skill. You may run read-only shell commands only to
open or hash the installed skill file named in the available-skills list. Do not
edit files.

Reply exactly in this format and nothing else, replacing HASH with the SHA-256
of the installed $host_runtime_skill SKILL.md file you inspected:

TRACEWEAVER_SKILL_HASH=HASH

If the skill is unavailable, not listed, not loaded, or cannot be used, reply
exactly with this one line and nothing else:

TRACEWEAVER_SKILL_HELD=not_available
EOF

if [ "$host_runtime_proof" = "requirements-review-output" ]; then
  if [ ! -f "$requirements_review_runtime_prompt" ]; then
    echo "missing_requirements_review_runtime_prompt=$requirements_review_runtime_prompt" >&2
    exit 67
  fi
  cp "$requirements_review_runtime_prompt" "$prompt"
fi

set +e
codex debug prompt-input "Use TraceWeaver required direct skills: tw-authority-gate tw-auto tw-strategy tw-ideate tw-plan tw-brainstorm tw-audit lfg tw-work tw-traceability-check tw-requirements-review tw-debug tw-code-review tw-doc-review tw-compound tw-compound-refresh tw-resolve-pr-feedback tw-sessions tw-test-browser tw-test-xcode tw-setup tw-worktree tw-commit tw-commit-push-pr tw-grill tw-update." >"$prompt_input" 2>"$runtime_tmp/prompt-input.err"
prompt_input_status=$?
set -e

if [ "$prompt_input_status" -eq 0 ]; then
  jq -r '.. | strings' "$prompt_input" | perl -ne 'print "$1\n" if /^- ([A-Za-z0-9_.:-]+): /' >"$visible_skills"
else
  : >"$visible_skills"
fi

missing_prompt_input_skills=()
for skill_name in "${required_direct_skills[@]}"; do
  if ! grep -qx "$skill_name" "$visible_skills"; then
    missing_prompt_input_skills+=("$skill_name")
  fi
done

if [ -f "$skills_root/tw-authority-gate/SKILL.md" ]; then
  expected_authority_gate_hash="$(hash_file "$skills_root/tw-authority-gate/SKILL.md")"
fi
if [ -f "$skills_root/$host_runtime_skill/SKILL.md" ]; then
  expected_runtime_skill_hash="$(hash_file "$skills_root/$host_runtime_skill/SKILL.md")"
fi

exec_status=99
normalized_message=""
if [ "$host_runtime_exec" = "1" ]; then
  set +e
  perl -e 'alarm shift; exec @ARGV' "$exec_timeout_seconds" codex exec \
    -m "$model" \
    -c "model_reasoning_effort=\"$reasoning_effort\"" \
    --sandbox read-only \
    --skip-git-repo-check \
    --ignore-rules \
    --output-last-message "$last_message" \
    --json <"$prompt" >"$events" 2>"$stderr_log"
  exec_status=$?
  set -e
  message="$(cat "$last_message" 2>/dev/null || true)"
  normalized_message="$(printf '%s' "$message" | tr -d '\r' | sed -e 's/[[:space:]]*$//')"
fi

echo "codex_host_skills_root=$skills_root"
echo "codex_host_active_skill_directory_count=$active_skill_directory_count"
echo "codex_host_compound_engineering_plugin_enabled=$ce_plugin_enabled"
echo "codex_host_required_skills=${required_direct_skills[*]}"
echo "codex_host_present_skills=${present[*]:-none}"
echo "codex_host_missing_skills=${missing[*]:-none}"
echo "codex_host_unmarked_skills=${unmarked[*]:-none}"
echo "codex_host_stale_skills=${stale[*]:-none}"
echo "codex_host_missing_skill_local_files=${missing_skill_local_files[*]:-none}"
echo "codex_host_stale_skill_local_files=${stale_skill_local_files[*]:-none}"
echo "codex_host_ce_derived_direct_callable_skills=${ce_direct_callable_skills[*]:-none}"
echo "codex_host_prompt_input=$prompt_input"
echo "codex_host_visible_skills=$visible_skills"
echo "codex_host_prompt_input_exit_code=$prompt_input_status"

if [ "${#native_missing[@]}" -gt 0 ]; then
  echo "codex_host_traceweaver_native_missing=${native_missing[*]}"
fi

if [ "${#missing_prompt_input_skills[@]}" -eq 0 ]; then
  echo "codex_host_prompt_input_registry_probe=pass_required_skills_visible"
  if [ "$ce_plugin_enabled" = "false" ]; then
    echo "codex_host_registry_visibility_condition=pass_required_skills_visible_with_external_ce_plugin_disabled"
  else
    echo "codex_host_registry_visibility_condition=pass_required_skills_visible_with_current_plugin_config"
  fi
else
  echo "codex_host_prompt_input_registry_probe=held_required_skills_not_visible"
  echo "codex_host_prompt_input_missing_skills=${missing_prompt_input_skills[*]}"
fi

if [ "${#missing[@]}" -eq 0 ] && [ "${#stale[@]}" -eq 0 ] && [ "${#unmarked[@]}" -eq 0 ] && [ "${#missing_skill_local_files[@]}" -eq 0 ] && [ "${#stale_skill_local_files[@]}" -eq 0 ] && [ "${#ce_direct_callable_skills[@]}" -eq 0 ]; then
  echo "codex_host_registry_filesystem_probe=pass_traceweaver_direct_callable_files_present"
  if [ "${#missing_prompt_input_skills[@]}" -eq 0 ]; then
    echo "host_codex_registry_discovery=pass_prompt_input_registry_required_skills_visible"
  else
    echo "host_codex_registry_discovery=held_active_session_callable_registry_not_proven"
  fi
else
  echo "codex_host_registry_filesystem_probe=held_missing_or_untrusted_direct_callable_files"
  if [ "${#ce_direct_callable_skills[@]}" -gt 0 ]; then
    echo "codex_host_ce_derived_direct_callable_surface=held_legacy_or_external_ce_callable_skills_present"
  fi
  echo "host_codex_registry_discovery=held_missing_traceweaver_direct_callable_host_install_or_active_registry_reload"
fi

echo "codex_host_runtime_exec_enabled=$host_runtime_exec"
echo "codex_host_runtime_skill=$host_runtime_skill"
echo "codex_host_runtime_proof=$host_runtime_proof"
echo "codex_host_runtime_model=$model"
echo "codex_host_runtime_reasoning_effort=$reasoning_effort"
echo "codex_host_model_default_policy_codex_model=$expected_codex_model"
echo "codex_host_model_default_policy_codex_reasoning_effort=$expected_codex_reasoning_effort"
echo "codex_host_model_default_policy_claude_model=$expected_claude_model"
echo "codex_host_model_default_policy_source_hash=${source_model_policy_hash:-missing}"
echo "codex_host_model_default_policy_host_hash=${host_model_policy_hash:-missing}"
if [ -n "$source_model_policy_hash" ] \
  && [ "$source_model_policy_hash" = "$host_model_policy_hash" ] \
  && grep -Fq "codex_model: $expected_codex_model" "$host_model_policy_reference" \
  && grep -Fq "codex_reasoning_effort: $expected_codex_reasoning_effort" "$host_model_policy_reference" \
  && grep -Fq "claude_model_family: $expected_claude_model" "$host_model_policy_reference"; then
  echo "codex_host_model_default_policy_reference=pass_source_host_hash_current"
else
  echo "codex_host_model_default_policy_reference=held_missing_or_stale"
fi
if [ "$model" = "$expected_codex_model" ] && [ "$reasoning_effort" = "$expected_codex_reasoning_effort" ]; then
  echo "codex_host_runtime_model_default_match=pass_default_runtime_args"
else
  echo "codex_host_runtime_model_default_match=pass_explicit_override_runtime_args"
fi
echo "codex_host_exec_events=$events"
echo "codex_host_exec_stderr=$stderr_log"
echo "codex_host_exec_last_message=$last_message"
echo "codex_host_expected_tw_authority_gate_hash=${expected_authority_gate_hash:-missing}"
echo "codex_host_expected_runtime_skill_hash=${expected_runtime_skill_hash:-missing}"
echo "codex_host_exec_exit_code=$exec_status"

host_registry_untrusted=0
if [ "${#missing[@]}" -ne 0 ] \
  || [ "${#stale[@]}" -ne 0 ] \
  || [ "${#unmarked[@]}" -ne 0 ] \
  || [ "${#missing_prompt_input_skills[@]}" -ne 0 ]; then
  host_registry_untrusted=1
fi

if [ "$host_runtime_exec" != "1" ]; then
  echo "real_tw_skill_runtime_invocation=held_host_runtime_exec_disabled"
elif [ "$exec_status" -ne 0 ]; then
  echo "real_tw_skill_runtime_invocation=held_host_codex_exec_failed"
elif [ "$normalized_message" = "TRACEWEAVER_SKILL_HELD=not_available" ] || printf '%s' "$normalized_message" | grep -Eiq "(not available|not listed|not loaded|cannot be used|unavailable|not found|no such skill)"; then
  echo "real_tw_skill_runtime_invocation=held_host_exec_skill_not_available"
elif [ "$host_runtime_proof" = "requirements-review-output" ]; then
  required_runtime_lines=(
    "TRACEWEAVER_TW_REQUIREMENTS_REVIEW_SENTINEL=pass"
    "TRACEWEAVER_TW_REQUIREMENTS_REVIEW_SKILL_HASH=$expected_runtime_skill_hash"
    "requirements_reviewed=REQ-TW-069"
    "classification=requirement"
    "quality_score=5"
    "default_outcome=Can approve"
    "score_boundary=triage_not_approval_authority"
    "requirement_set_quality_findings=none"
    "authority_ready=static_advisory_only"
    "publication=held"
    "accepted_traceweaver_input=false"
  )
  missing_runtime_line=""
  for runtime_line in "${required_runtime_lines[@]}"; do
    if ! grep -Fxq "$runtime_line" "$last_message"; then
      missing_runtime_line="$runtime_line"
      break
    fi
  done
  if [ -n "$missing_runtime_line" ]; then
    echo "real_tw_skill_runtime_invocation=held_requirements_review_output_missing_required_field"
    echo "real_tw_requirements_review_missing_runtime_field=$missing_runtime_line"
  elif [ "$host_registry_untrusted" -ne 0 ]; then
    echo "real_tw_skill_runtime_invocation=held_host_registry_untrusted_after_requirements_review_output"
  else
    echo "real_tw_skill_runtime_invocation=pass_host_tw_requirements_review_runtime_output_fixture"
  fi
elif [ -n "$expected_runtime_skill_hash" ] && [ "$normalized_message" = "TRACEWEAVER_SKILL_HASH=$expected_runtime_skill_hash" ] && [ "$host_registry_untrusted" -ne 0 ]; then
  echo "real_tw_skill_runtime_invocation=held_host_registry_untrusted_after_skill_hash_sentinel"
elif [ -n "$expected_runtime_skill_hash" ] && [ "$normalized_message" = "TRACEWEAVER_SKILL_HASH=$expected_runtime_skill_hash" ]; then
  normalized_runtime_skill="${host_runtime_skill//-/_}"
  echo "real_tw_skill_runtime_invocation=pass_host_${normalized_runtime_skill}_skill_file_read"
else
  echo "real_tw_skill_runtime_invocation=held_host_exec_unclassified_transcript"
fi
