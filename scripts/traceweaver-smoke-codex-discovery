#!/usr/bin/env bash
set -euo pipefail

# TRACEWEAVER: file-role=install-discovery-smoke; req=REQ-TW-052; trace=TRACE-TW-037; ver=VER-TW-047
# TRACEWEAVER: verifies=VER-TW-047; req=REQ-TW-052; trace=TRACE-TW-037
# TRACEWEAVER: file-role=install-discovery-smoke; req=REQ-TW-057; trace=TRACE-TW-032; ver=VER-TW-041
# TRACEWEAVER: verifies=VER-TW-041; req=REQ-TW-057; trace=TRACE-TW-032
# TRACEWEAVER: file-role=model-default-install-discovery-smoke; req=REQ-TW-060; trace=TRACE-TW-043; ver=VER-TW-055
# TRACEWEAVER: verifies=VER-TW-055; req=REQ-TW-060; trace=TRACE-TW-043
# TRACEWEAVER: file-role=systems-engineering-audit-install-discovery-smoke; req=REQ-TW-061; trace=TRACE-TW-044; ver=VER-TW-056
# TRACEWEAVER: verifies=VER-TW-056; req=REQ-TW-061; trace=TRACE-TW-044

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmp_root="$(mktemp -d)"
trap 'rm -rf "$tmp_root"' EXIT

hash_file() {
  shasum -a 256 "$1" | awk '{print $1}'
}

json_query() {
  python3 - "$1" "$2" <<'PY'
import json
import sys

path = sys.argv[1]
query = sys.argv[2].split(".")
with open(path, "r", encoding="utf-8") as handle:
    value = json.load(handle)
for part in query:
    value = value[part]
if isinstance(value, list):
    print("\n".join(str(item) for item in value))
else:
    print(value)
PY
}

json_len() {
  python3 - "$1" "$2" <<'PY'
import json
import sys

path = sys.argv[1]
query = sys.argv[2].split(".")
with open(path, "r", encoding="utf-8") as handle:
    value = json.load(handle)
for part in query:
    value = value[part]
print(len(value))
PY
}

json_bool() {
  python3 - "$1" "$2" <<'PY'
import json
import sys

path = sys.argv[1]
query = sys.argv[2].split(".")
with open(path, "r", encoding="utf-8") as handle:
    value = json.load(handle)
for part in query:
    value = value[part]
if value is True:
    print("true")
elif value is False:
    print("false")
else:
    raise SystemExit(f"{'.'.join(query)} is not boolean: {value!r}")
PY
}

assert_file() {
  if [ ! -f "$1" ]; then
    echo "missing_file=$1"
    exit 1
  fi
}

assert_dir() {
  if [ ! -d "$1" ]; then
    echo "missing_directory=$1"
    exit 1
  fi
}

assert_equal() {
  local label="$1"
  local expected="$2"
  local actual="$3"
  if [ "$expected" != "$actual" ]; then
    echo "${label}=failed expected=${expected} actual=${actual}"
    exit 1
  fi
}

assert_marker() {
  local marker="$1"
  local expected_skill="$2"
  python3 - "$marker" "$expected_skill" <<'PY'
import json
import sys

marker_path, expected_skill = sys.argv[1], sys.argv[2]
with open(marker_path, "r", encoding="utf-8") as handle:
    marker = json.load(handle)
expected = {
    "plugin": "traceweaver-core",
    "skill": expected_skill,
    "purpose": "direct-callable-skill-copy",
}
for key, value in expected.items():
    if marker.get(key) != value:
        raise SystemExit(f"marker_{key}=failed expected={value} actual={marker.get(key)}")
PY
}

expected_direct_skills=(
  tw-auto
  tw-strategy
  tw-ideate
  tw-plan
  tw-brainstorm
  tw-audit
  lfg
  tw-authority-gate
  tw-work
  tw-traceability-check
  tw-requirements-review
  tw-debug
  tw-code-review
  tw-doc-review
  tw-commit
  tw-commit-push-pr
  tw-compound
  tw-compound-refresh
  tw-resolve-pr-feedback
  tw-sessions
  tw-test-browser
  tw-test-xcode
  tw-setup
  tw-worktree
  tw-update
  tw-grill
)

expected_visible_skills=(
  tw-auto
  tw-strategy
  tw-ideate
  tw-plan
  tw-brainstorm
  tw-audit
  lfg
  tw-authority-gate
  tw-work
  tw-traceability-check
  tw-requirements-review
  tw-debug
  tw-code-review
  tw-doc-review
  tw-commit
  tw-commit-push-pr
  tw-compound
  tw-compound-refresh
  tw-resolve-pr-feedback
  tw-sessions
  tw-test-browser
  tw-test-xcode
  tw-setup
  tw-worktree
  tw-update
  tw-grill
)

identity_skills=(
  tw-auto
  tw-strategy
  tw-ideate
  tw-plan
  tw-brainstorm
  tw-audit
  lfg
  tw-authority-gate
  tw-work
  tw-traceability-check
  tw-requirements-review
  tw-debug
  tw-code-review
  tw-doc-review
  tw-commit
  tw-commit-push-pr
  tw-compound
  tw-compound-refresh
  tw-resolve-pr-feedback
  tw-sessions
  tw-test-browser
  tw-test-xcode
  tw-setup
  tw-worktree
  tw-update
  tw-grill
)

expected_internal_packaged_skills=(
  ce-brainstorm
  ce-code-review
  ce-commit
  ce-commit-push-pr
  ce-compound
  ce-compound-refresh
  ce-debug
  ce-doc-review
  ce-ideate
  ce-plan
  ce-resolve-pr-feedback
  ce-sessions
  ce-setup
  ce-strategy
  ce-test-browser
  ce-test-xcode
  ce-work
  ce-worktree
  requirements-reviewer
  systems-engineering-traceability
  using-agent-skills
)

identity_skills+=(
  ce-debug
  ce-commit
  ce-commit-push-pr
)

required_skill_local_files=(
  "tw-traceability-check/references/traceweaver-operating-modes.md"
  "tw-code-review/references/traceweaver-operating-modes.md"
  "tw-doc-review/references/traceweaver-operating-modes.md"
  "tw-auto/references/traceweaver-operating-modes.md"
  "tw-audit/references/traceweaver-operating-modes.md"
  "tw-strategy/references/traceweaver-operating-modes.md"
  "tw-ideate/references/traceweaver-operating-modes.md"
  "tw-plan/references/traceweaver-operating-modes.md"
  "tw-work/references/traceweaver-operating-modes.md"
  "tw-brainstorm/references/traceweaver-operating-modes.md"
  "tw-compound/references/traceweaver-operating-modes.md"
  "tw-compound-refresh/references/traceweaver-operating-modes.md"
  "tw-resolve-pr-feedback/references/traceweaver-operating-modes.md"
  "tw-sessions/references/traceweaver-operating-modes.md"
  "tw-test-browser/references/traceweaver-operating-modes.md"
  "tw-test-xcode/references/traceweaver-operating-modes.md"
  "tw-setup/references/traceweaver-operating-modes.md"
  "tw-worktree/references/traceweaver-operating-modes.md"
  "tw-traceability-check/references/code-trace-anchor-contract.md"
  "tw-traceability-check/references/trace-anchor-authoring.md"
  "tw-work/references/trace-anchor-authoring.md"
  "tw-code-review/references/trace-anchor-authoring.md"
  "tw-doc-review/references/trace-anchor-authoring.md"
  "tw-auto/references/trace-anchor-authoring.md"
  "tw-traceability-check/scripts/traceweaver-check-code-anchors"
  "tw-traceability-check/scripts/traceweaver-author-code-anchors"
)

codex_home="$tmp_root/codex-home"
mkdir -p "$codex_home"

install_output="$tmp_root/install.out"
bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$codex_home" >"$install_output"

codex_root="$codex_home/.codex"
manifest="$codex_root/traceweaver-core/install-manifest.json"
packaged_skills_root="$codex_root/traceweaver-core/skills"
callable_skills_root="$codex_root/skills"
agents_root="$codex_root/agents/traceweaver-core"
references_root="$codex_root/traceweaver-core/references"
visible_skills="$tmp_root/visible-skills.txt"

assert_file "$manifest"
assert_dir "$packaged_skills_root"
assert_dir "$callable_skills_root"
assert_dir "$agents_root"
assert_dir "$references_root"

if [ -d "$codex_root/skills/traceweaver-core" ]; then
  echo "active_namespaced_skill_surface=failed path=$codex_root/skills/traceweaver-core"
  exit 1
fi

source_skill_count="$(find "$repo_root/plugins/traceweaver-core/skills" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
source_agent_count="$(find "$repo_root/plugins/traceweaver-core/agents" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
source_reference_count="$(find "$repo_root/plugins/traceweaver-core/references" -type f | wc -l | tr -d ' ')"

manifest_skill_count="$(json_len "$manifest" skills)"
manifest_callable_count="$(json_len "$manifest" callableSkills)"
manifest_agent_count="$(json_len "$manifest" agents)"
manifest_reference_count="$(json_len "$manifest" references)"
manifest_prompt_count="$(json_len "$manifest" prompts)"
manifest_prompt_file_count="$(json_len "$manifest" promptFiles)"

installed_packaged_count="$(find "$packaged_skills_root" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
installed_callable_count=0
for skill_name in $(json_query "$manifest" callableSkills); do
  assert_dir "$callable_skills_root/$skill_name"
  assert_file "$callable_skills_root/$skill_name/.traceweaver-core-install.json"
  assert_marker "$callable_skills_root/$skill_name/.traceweaver-core-install.json" "$skill_name"
  installed_callable_count=$((installed_callable_count + 1))
done

assert_equal "manifest_skill_count" "$source_skill_count" "$manifest_skill_count"
assert_equal "manifest_callable_skill_count" "${#expected_direct_skills[@]}" "$manifest_callable_count"
assert_equal "manifest_agent_count" "$source_agent_count" "$manifest_agent_count"
assert_equal "manifest_reference_count" "$source_reference_count" "$manifest_reference_count"
assert_equal "manifest_prompt_count" "0" "$manifest_prompt_count"
assert_equal "manifest_prompt_file_count" "0" "$manifest_prompt_file_count"
assert_equal "installed_packaged_skill_count" "$source_skill_count" "$installed_packaged_count"
assert_equal "installed_callable_skill_count" "${#expected_direct_skills[@]}" "$installed_callable_count"
assert_equal "manifest_standalone" "true" "$(json_bool "$manifest" standalone)"
assert_equal "manifest_external_ce_plugin_required" "false" "$(json_bool "$manifest" externalCePluginRequired)"
assert_equal "manifest_ce_derived_components_owner" "traceweaver-core" "$(json_query "$manifest" ceDerivedComponentsOwner)"
assert_equal "manifest_model_default_codex_model" "gpt-5.5" "$(json_query "$manifest" modelDefaults.codex.model)"
assert_equal "manifest_model_default_codex_reasoning_effort" "medium" "$(json_query "$manifest" modelDefaults.codex.reasoningEffort)"
assert_equal "manifest_model_default_codex_model_override_env" "TRACEWEAVER_CODEX_MODEL" "$(json_query "$manifest" modelDefaults.codex.overrideEnvironment.model)"
assert_equal "manifest_model_default_codex_reasoning_override_env" "TRACEWEAVER_CODEX_REASONING_EFFORT" "$(json_query "$manifest" modelDefaults.codex.overrideEnvironment.reasoningEffort)"
assert_equal "manifest_model_default_claude_model" "sonnet" "$(json_query "$manifest" modelDefaults.claude.model)"
assert_equal "manifest_model_default_claude_enforcement" "policy_recorded_runtime_enforcement_held" "$(json_query "$manifest" modelDefaults.claude.enforcement)"
assert_equal "manifest_model_default_ce_body_policy" "no_model_default_edits_without_reviewed_overlay_fork_record" "$(json_query "$manifest" modelDefaults.importedCeComponentBodyPolicy)"
if grep -Fq '"modelDefaults"' "$repo_root/plugins/traceweaver-core/.codex-plugin/plugin.json" \
  || grep -Fq '"modelDefaults"' "$repo_root/plugins/traceweaver-core/.claude-plugin/plugin.json"; then
  echo "plugin_manifest_model_defaults=failed_manifest_contains_loader_unsafe_policy"
  exit 1
fi
echo "plugin_manifest_model_defaults=pass_policy_kept_in_reference_and_install_manifest"
grep -Fq "legacy_active_namespaced_skill_surface=absent" "$install_output"

if find "$codex_root" -path '*compound-engineering*' -print -quit | grep -q .; then
  echo "external_compound_engineering_plugin_surface=failed unexpected_path=$(find "$codex_root" -path '*compound-engineering*' -print -quit)"
  exit 1
fi

if [ -f "$codex_root/config.toml" ] && grep -Fq 'compound-engineering@compound-engineering-plugin' "$codex_root/config.toml"; then
  echo "external_compound_engineering_plugin_config=failed path=$codex_root/config.toml"
  exit 1
fi

for skill_name in "${expected_direct_skills[@]}"; do
  assert_dir "$packaged_skills_root/$skill_name"
  assert_dir "$callable_skills_root/$skill_name"
done

for skill_name in "${expected_internal_packaged_skills[@]}"; do
  assert_dir "$packaged_skills_root/$skill_name"
  if [ -e "$callable_skills_root/$skill_name" ]; then
    echo "internal_packaged_skill_direct_callable=failed skill=$skill_name"
    exit 1
  fi
done

for skill_name in "${identity_skills[@]}"; do
  source_hash="$(hash_file "$repo_root/plugins/traceweaver-core/skills/$skill_name/SKILL.md")"
  packaged_hash="$(hash_file "$packaged_skills_root/$skill_name/SKILL.md")"
  assert_equal "${skill_name}_packaged_hash" "$source_hash" "$packaged_hash"
  if [ -f "$callable_skills_root/$skill_name/SKILL.md" ]; then
    callable_hash="$(hash_file "$callable_skills_root/$skill_name/SKILL.md")"
    assert_equal "${skill_name}_callable_hash" "$source_hash" "$callable_hash"
  fi
  echo "skill_hash_${skill_name}=${source_hash}"
done

for skill_local_file in "${required_skill_local_files[@]}"; do
  source_file="$repo_root/plugins/traceweaver-core/skills/$skill_local_file"
  packaged_file="$packaged_skills_root/$skill_local_file"
  callable_file="$callable_skills_root/$skill_local_file"
  assert_file "$source_file"
  assert_file "$packaged_file"
  assert_file "$callable_file"
  source_hash="$(hash_file "$source_file")"
  packaged_hash="$(hash_file "$packaged_file")"
  callable_hash="$(hash_file "$callable_file")"
  label="$(printf '%s' "$skill_local_file" | tr '/.-' '___')"
  assert_equal "${label}_packaged_hash" "$source_hash" "$packaged_hash"
  assert_equal "${label}_callable_hash" "$source_hash" "$callable_hash"
  echo "skill_local_file_hash_${label}=${source_hash}"
done

assert_file "$references_root/traceweaver-model-defaults.md"
grep -Fq "codex_model: gpt-5.5" "$references_root/traceweaver-model-defaults.md"
grep -Fq "codex_reasoning_effort: medium" "$references_root/traceweaver-model-defaults.md"
grep -Fq "claude_model_family: sonnet" "$references_root/traceweaver-model-defaults.md"
assert_file "$references_root/traceweaver-systems-engineering-audit-closure.md"
grep -Fq "User-Facing Skill Prompt Contract" "$references_root/traceweaver-systems-engineering-audit-closure.md"
grep -Fq "Requirement Closure Contract" "$references_root/traceweaver-systems-engineering-audit-closure.md"
grep -Fq "Semantic Audit Mode Contract" "$references_root/traceweaver-systems-engineering-audit-closure.md"

ce_policy_grep="$tmp_root/model-default-ce-body-grep.txt"
if grep -R -nE 'REQ-TW-060|gpt-5\.5|TRACEWEAVER_CODEX_MODEL|TRACEWEAVER_CODEX_REASONING_EFFORT|model-default|model default' \
  "$repo_root/plugins/traceweaver-core/skills"/ce-* \
  "$repo_root/plugins/traceweaver-core/agents"/ce-*.md >"$ce_policy_grep" 2>/dev/null; then
  echo "model_default_ce_body_drift_guard=failed_model_policy_marker_in_imported_ce_body"
  cat "$ce_policy_grep"
  exit 1
fi

HOME="$codex_home" CODEX_HOME="$codex_root" codex debug prompt-input \
  "Use all TraceWeaver direct skills: tw-auto tw-strategy tw-ideate tw-plan tw-brainstorm tw-audit tw-authority-gate tw-work tw-traceability-check tw-requirements-review tw-debug tw-code-review tw-doc-review tw-compound tw-compound-refresh tw-resolve-pr-feedback tw-sessions tw-test-browser tw-test-xcode tw-setup tw-worktree tw-grill lfg." \
  | jq -r '.. | strings' \
  | perl -ne 'print "$1\n" if /^- ([A-Za-z0-9_.:-]+): /' \
  | sort -u >"$visible_skills"

for skill_name in "${expected_visible_skills[@]}"; do
  if ! grep -qx "$skill_name" "$visible_skills"; then
    echo "codex_prompt_input_visible_skill=failed missing=$skill_name"
    echo "visible_skills=$(paste -sd, "$visible_skills")"
    exit 1
  fi
done

grep -Fq "Invoke \`tw-auto\` with the same arguments" "$callable_skills_root/lfg/SKILL.md"
grep -Fq "Do not run \`ce-plan\`, \`ce-work\`, \`ce-code-review\`, \`ce-commit\`" "$callable_skills_root/lfg/SKILL.md"
grep -Fq "Do not fall back to raw CE \`lfg\`" "$callable_skills_root/lfg/SKILL.md"

if [ -d "$codex_root/prompts" ] || [ -d "$codex_root/commands" ]; then
  echo "prompt_or_command_surface=failed"
  exit 1
fi

conflict_home="$tmp_root/conflict-home"
mkdir -p "$conflict_home/.codex/skills/tw-work"
printf 'unowned skill\n' >"$conflict_home/.codex/skills/tw-work/SKILL.md"

set +e
bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$conflict_home" >"$tmp_root/conflict.out" 2>"$tmp_root/conflict.err"
conflict_status=$?
set -e

if [ "$conflict_status" -eq 0 ]; then
  echo "unowned_direct_callable_conflict=failed expected_nonzero"
  exit 1
fi

if ! grep -Fq "will not overwrite existing global callable skill directories" "$tmp_root/conflict.err"; then
  echo "unowned_direct_callable_conflict_message=failed"
  cat "$tmp_root/conflict.err"
  exit 1
fi

assert_equal "unowned_conflict_file_preserved" "unowned skill" "$(cat "$conflict_home/.codex/skills/tw-work/SKILL.md")"

ce_conflict_home="$tmp_root/ce-conflict-home"
mkdir -p "$ce_conflict_home/.codex/skills/ce-work"
printf 'external ce work\n' >"$ce_conflict_home/.codex/skills/ce-work/SKILL.md"

set +e
bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$ce_conflict_home" >"$tmp_root/ce-conflict.out" 2>"$tmp_root/ce-conflict.err"
ce_conflict_status=$?
set -e

if [ "$ce_conflict_status" -eq 0 ]; then
  echo "unowned_ce_direct_callable_conflict=failed expected_nonzero"
  exit 1
fi

if ! grep -Fq "found existing direct ce-* skill directories" "$tmp_root/ce-conflict.err"; then
  echo "unowned_ce_direct_callable_conflict_message=failed"
  cat "$tmp_root/ce-conflict.err"
  exit 1
fi

assert_equal "unowned_ce_conflict_file_preserved" "external ce work" "$(cat "$ce_conflict_home/.codex/skills/ce-work/SKILL.md")"

legacy_home="$tmp_root/legacy-home"
legacy_codex_root="$legacy_home/.codex"
legacy_active_root="$legacy_codex_root/skills/traceweaver-core"
legacy_manifest_dir="$legacy_codex_root/traceweaver-core"
mkdir -p "$legacy_active_root/tw-auto" "$legacy_manifest_dir"
printf 'legacy active traceweaver skill\n' >"$legacy_active_root/tw-auto/SKILL.md"
cat >"$legacy_manifest_dir/install-manifest.json" <<'JSON'
{
  "plugin": "traceweaver-core",
  "target": "codex",
  "includeSkills": true,
  "skills": ["tw-auto"],
  "callableSkills": ["tw-auto"]
}
JSON

legacy_install_output="$tmp_root/legacy-install.out"
bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$legacy_home" >"$legacy_install_output"

if [ -d "$legacy_active_root" ]; then
  echo "owned_legacy_active_skill_surface_cleanup=failed path=$legacy_active_root"
  exit 1
fi
grep -Fq "legacy_active_namespaced_skill_surface=removed_owned_upgrade" "$legacy_install_output"
assert_dir "$legacy_codex_root/traceweaver-core/skills/tw-auto"
assert_dir "$legacy_codex_root/skills/tw-auto"

unowned_legacy_home="$tmp_root/unowned-legacy-home"
unowned_legacy_codex_root="$unowned_legacy_home/.codex"
unowned_legacy_active_root="$unowned_legacy_codex_root/skills/traceweaver-core"
mkdir -p "$unowned_legacy_active_root/tw-auto"
printf 'unowned legacy active skill\n' >"$unowned_legacy_active_root/tw-auto/SKILL.md"

set +e
bun run "$repo_root/src/index.ts" install "$repo_root/plugins/traceweaver-core" \
  --to codex \
  --include-skills \
  --codexHome "$unowned_legacy_home" >"$tmp_root/unowned-legacy.out" 2>"$tmp_root/unowned-legacy.err"
unowned_legacy_status=$?
set -e

if [ "$unowned_legacy_status" -eq 0 ]; then
  echo "unowned_legacy_active_skill_surface=failed expected_nonzero"
  exit 1
fi

if ! grep -Fq "will not remove legacy active TraceWeaver skill surface without ownership proof" "$tmp_root/unowned-legacy.err"; then
  echo "unowned_legacy_active_skill_surface_message=failed"
  cat "$tmp_root/unowned-legacy.err"
  exit 1
fi

assert_equal "unowned_legacy_active_file_preserved" "unowned legacy active skill" "$(cat "$unowned_legacy_active_root/tw-auto/SKILL.md")"

echo "codex_discovery_smoke=pass"
echo "temp_codex_home=$codex_home"
echo "installed_manifest=$manifest"
echo "installed_packaged_skill_directory_count=$installed_packaged_count"
echo "installed_callable_skill_directory_count=$installed_callable_count"
echo "installed_agent_toml_count=$manifest_agent_count"
echo "installed_reference_file_count=$manifest_reference_count"
echo "installed_manifest_prompts=$manifest_prompt_count"
echo "installed_manifest_prompt_files=$manifest_prompt_file_count"
echo "installed_manifest_standalone=true"
echo "installed_external_ce_plugin_required=false"
echo "installed_ce_derived_components_owner=traceweaver-core"
echo "installed_ce_derived_components_direct_callable=false"
echo "installed_model_default_codex_model=gpt-5.5"
echo "installed_model_default_codex_reasoning_effort=medium"
echo "installed_model_default_claude_model=sonnet"
echo "installed_model_default_policy_reference=present"
echo "model_default_ce_body_drift_guard=pass_no_req_tw_060_model_policy_in_imported_ce_bodies"
echo "external_compound_engineering_plugin_surface=absent"
echo "external_compound_engineering_plugin_config=absent"
echo "internal_packaged_skills_not_direct_callable=${expected_internal_packaged_skills[*]}"
echo "direct_callable_required_skills=${expected_direct_skills[*]}"
echo "codex_prompt_input_visible_required_skills=${expected_visible_skills[*]}"
echo "active_namespaced_skill_surface=absent"
echo "packaged_traceweaver_skills_root=$packaged_skills_root"
