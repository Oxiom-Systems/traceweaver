#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

gh_marker="$tmp_dir/gh-called"
mkdir -p "$tmp_dir/bin"
cat >"$tmp_dir/bin/gh" <<'SH'
#!/usr/bin/env bash
echo "gh called: $*" >>"${TRACEWEAVER_GH_MARKER:?}"
exit 98
SH
chmod +x "$tmp_dir/bin/gh"

export PATH="$tmp_dir/bin:$PATH"
export TRACEWEAVER_GH_MARKER="$gh_marker"
unset TRACEWEAVER_PUBLICATION_GATE

reply_script="$repo_root/plugins/traceweaver-core/skills/ce-resolve-pr-feedback/scripts/reply-to-pr-thread"
resolve_script="$repo_root/plugins/traceweaver-core/skills/ce-resolve-pr-feedback/scripts/resolve-pr-thread"

set +e
printf 'draft reply with no publication\n' | "$reply_script" THREAD_test >"$tmp_dir/reply.out" 2>"$tmp_dir/reply.err"
reply_status=$?
"$resolve_script" THREAD_test >"$tmp_dir/resolve.out" 2>"$tmp_dir/resolve.err"
resolve_status=$?
export TRACEWEAVER_PUBLICATION_GATE=approved
printf 'draft reply with attempted bypass\n' | "$reply_script" THREAD_bypass >"$tmp_dir/reply-bypass.out" 2>"$tmp_dir/reply-bypass.err"
reply_bypass_status=$?
"$resolve_script" THREAD_bypass >"$tmp_dir/resolve-bypass.out" 2>"$tmp_dir/resolve-bypass.err"
resolve_bypass_status=$?
set -e

if [ "$reply_status" -ne 2 ]; then
  echo "reply_to_pr_thread_expected_exit_2=failed actual=$reply_status"
  exit 1
fi

if [ "$resolve_status" -ne 2 ]; then
  echo "resolve_pr_thread_expected_exit_2=failed actual=$resolve_status"
  exit 1
fi

if [ "$reply_bypass_status" -ne 2 ]; then
  echo "reply_to_pr_thread_bypass_expected_exit_2=failed actual=$reply_bypass_status"
  exit 1
fi

if [ "$resolve_bypass_status" -ne 2 ]; then
  echo "resolve_pr_thread_bypass_expected_exit_2=failed actual=$resolve_bypass_status"
  exit 1
fi

if [ -f "$gh_marker" ]; then
  echo "gh_invocation=failed"
  cat "$gh_marker"
  exit 1
fi

grep -Fq "direct invocation" "$repo_root/plugins/traceweaver-core/skills/ce-commit/SKILL.md"
grep -Fq "do not stage, commit, push, or publish" "$repo_root/plugins/traceweaver-core/skills/ce-debug/SKILL.md"
grep -Fq "unstaged alongside the other uncommitted refresh changes" "$repo_root/plugins/traceweaver-core/skills/ce-compound-refresh/SKILL.md"
grep -Fq "posting PR comments, or resolving review threads" "$repo_root/plugins/traceweaver-core/skills/ce-resolve-pr-feedback/SKILL.md"
grep -Fq "Do not edit project context or authority documents" "$repo_root/plugins/traceweaver-core/skills/tw-grill/SKILL.md"
grep -Fq "Invoke \`tw-auto\` with the same arguments" "$repo_root/plugins/traceweaver-core/skills/lfg/SKILL.md"
grep -Fq "Do not run \`ce-plan\`, \`ce-work\`, \`ce-code-review\`, \`ce-commit\`" "$repo_root/plugins/traceweaver-core/skills/lfg/SKILL.md"
grep -Fq "Do not fall back to raw CE \`lfg\`" "$repo_root/plugins/traceweaver-core/skills/lfg/SKILL.md"
grep -Fq "agent thread limit reached" "$repo_root/plugins/traceweaver-core/skills/tw-auto/SKILL.md"
grep -Fq "pending queue" "$repo_root/plugins/traceweaver-core/skills/tw-auto/SKILL.md"
grep -Fq "does not close U9, runtime, release, or" "$repo_root/plugins/traceweaver-core/skills/tw-auto/SKILL.md"
grep -Fq "required-review gates" "$repo_root/plugins/traceweaver-core/skills/tw-auto/SKILL.md"

review_capacity=1
intended_reviewers=(ce-coherence-reviewer ce-feasibility-reviewer ce-scope-guardian-reviewer)
queued_reviewers=("${intended_reviewers[@]}")
active_reviewers=()
completed_reviewers=()
closed_reviewers=()
capacity_errors=()
dispatch_events=()

join_by_space() {
  local IFS=" "
  echo "$*"
}

dispatch_reviewer() {
  local reviewer="$1"
  if [ "${#active_reviewers[@]}" -ge "$review_capacity" ]; then
    capacity_errors+=("agent thread limit reached:$reviewer")
    dispatch_events+=("capacity:$reviewer")
    return 1
  fi
  active_reviewers+=("$reviewer")
  dispatch_events+=("dispatched:$reviewer")
  return 0
}

complete_active_reviewer() {
  local reviewer="$1"
  local next_active=()
  local found=0
  for active in "${active_reviewers[@]}"; do
    if [ "$active" = "$reviewer" ]; then
      found=1
      completed_reviewers+=("$reviewer")
      dispatch_events+=("completed:$reviewer")
    else
      next_active+=("$active")
    fi
  done
  if [ "$found" -ne 1 ]; then
    echo "reviewer_backpressure_fixture=failed_complete_unknown_reviewer:$reviewer"
    exit 1
  fi
  active_reviewers=()
  if [ "${#next_active[@]}" -gt 0 ]; then
    active_reviewers=("${next_active[@]}")
  fi
}

close_completed_reviewer() {
  local reviewer="$1"
  for completed in "${completed_reviewers[@]}"; do
    if [ "$completed" = "$reviewer" ]; then
      closed_reviewers+=("$reviewer")
      dispatch_events+=("closed:$reviewer")
      return 0
    fi
  done
  echo "reviewer_backpressure_fixture=failed_close_uncompleted_reviewer:$reviewer"
  exit 1
}

remove_queued_reviewer() {
  local reviewer="$1"
  local next_queue=()
  for queued in "${queued_reviewers[@]}"; do
    if [ "$queued" != "$reviewer" ]; then
      next_queue+=("$queued")
    fi
  done
  queued_reviewers=()
  if [ "${#next_queue[@]}" -gt 0 ]; then
    queued_reviewers=("${next_queue[@]}")
  fi
}

dispatch_reviewer "ce-coherence-reviewer" || true
remove_queued_reviewer "ce-coherence-reviewer"
dispatch_reviewer "ce-feasibility-reviewer" || true
complete_active_reviewer "ce-coherence-reviewer"
close_completed_reviewer "ce-coherence-reviewer"
dispatch_reviewer "ce-feasibility-reviewer" || true
remove_queued_reviewer "ce-feasibility-reviewer"
dispatch_reviewer "ce-scope-guardian-reviewer" || true

pending_reviewers=("${queued_reviewers[@]}")
if [ "${#active_reviewers[@]}" -gt 0 ]; then
  pending_reviewers+=("${active_reviewers[@]}")
fi

if [ "${#capacity_errors[@]}" -eq 0 ]; then
  echo "reviewer_backpressure_fixture=failed_missing_capacity_error"
  exit 1
fi

if [ "$(join_by_space "${closed_reviewers[@]}")" != "ce-coherence-reviewer" ]; then
  echo "reviewer_backpressure_fixture=failed_missing_close_after_completion"
  exit 1
fi

if [ "${#pending_reviewers[@]}" -eq 0 ]; then
  echo "reviewer_backpressure_fixture=failed_missing_pending_reviewers"
  exit 1
fi

if [ "${#completed_reviewers[@]}" -eq "${#intended_reviewers[@]}" ]; then
  review_gate_status="passed"
else
  review_gate_status="held_incomplete_reviewer_coverage"
fi

if [ "$review_gate_status" = "passed" ]; then
  echo "reviewer_backpressure_fixture=failed_gate_closed"
  exit 1
fi

human_degraded_acceptance="held_condition_recorded_not_gate_closure"
if [ "$human_degraded_acceptance" != "held_condition_recorded_not_gate_closure" ]; then
  echo "degraded_review_acceptance_fixture=failed_gate_closed"
  exit 1
fi

echo "no_publication_smoke=pass"
echo "reply_to_pr_thread_without_gate=blocked_before_gh"
echo "resolve_pr_thread_without_gate=blocked_before_gh"
echo "reply_to_pr_thread_env_bypass=blocked_before_gh"
echo "resolve_pr_thread_env_bypass=blocked_before_gh"
echo "skill_publication_stop_markers=present"
echo "lfg_delegation=pass"
echo "lfg_no_raw_ce_autopilot=pass"
echo "pr_helper_publication_stop_before_external_mutation=pass"
echo "publication_stop_static_markers=present"
echo "reviewer_backpressure=incomplete_coverage_no_gate_closure events=$(join_by_space "${dispatch_events[@]}") capacity_errors=$(join_by_space "${capacity_errors[@]}") intended=$(join_by_space "${intended_reviewers[@]}") completed=$(join_by_space "${completed_reviewers[@]}") closed=$(join_by_space "${closed_reviewers[@]}") pending=$(join_by_space "${pending_reviewers[@]}")"
echo "degraded_review_acceptance=held_condition_not_gate_closure"
echo "unit4_boundary_smoke=pass"
