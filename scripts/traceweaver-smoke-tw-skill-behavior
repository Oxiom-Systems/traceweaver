active_host_review_routing_hashes_current() {
  [[ "$host_auto_hash" == "$repo_auto_hash" &&
     "$host_strategy_hash" == "$repo_strategy_hash" &&
     "$host_ideate_hash" == "$repo_ideate_hash" &&
     "$host_plan_hash" == "$repo_plan_hash" &&
     "$host_authority_gate_hash" == "$repo_authority_gate_hash" &&
     "$host_audit_hash" == "$repo_audit_hash" &&
     "$host_work_hash" == "$repo_work_hash" &&
     "$host_trace_hash" == "$repo_trace_hash" &&
     "$host_structured_ref_hash" == "$repo_structured_ref_hash" &&
     "$host_code_anchor_scanner_hash" == "$repo_code_anchor_scanner_hash" &&
     "$host_code_anchor_author_hash" == "$repo_code_anchor_author_hash" &&
     "$host_code_hash" == "$repo_code_hash" &&
     "$host_doc_hash" == "$repo_doc_hash" &&
     "$host_brainstorm_hash" == "$repo_brainstorm_hash" &&
     "$host_compound_hash" == "$repo_compound_hash" &&
     "$host_compound_refresh_hash" == "$repo_compound_refresh_hash" &&
     "$host_resolve_pr_feedback_hash" == "$repo_resolve_pr_feedback_hash" &&
     "$host_sessions_hash" == "$repo_sessions_hash" &&
     "$host_test_browser_hash" == "$repo_test_browser_hash" &&
     "$host_test_xcode_hash" == "$repo_test_xcode_hash" &&
     "$host_setup_hash" == "$repo_setup_hash" &&
     "$host_worktree_hash" == "$repo_worktree_hash" &&
     "$host_ce_plan_hash" == "$repo_ce_plan_hash" &&
     "$host_ce_work_hash" == "$repo_ce_work_hash" &&
     "$host_ce_code_hash" == "$repo_ce_code_hash" &&
     "$host_ce_doc_hash" == "$repo_ce_doc_hash" &&
     "$host_ce_strategy_hash" == "$repo_ce_strategy_hash" &&
     "$host_ce_ideate_hash" == "$repo_ce_ideate_hash" &&
     "$host_ce_brainstorm_hash" == "$repo_ce_brainstorm_hash" &&
     "$host_ce_compound_hash" == "$repo_ce_compound_hash" &&
     "$host_ce_compound_refresh_hash" == "$repo_ce_compound_refresh_hash" &&
     "$host_ce_resolve_pr_feedback_hash" == "$repo_ce_resolve_pr_feedback_hash" &&
     "$host_ce_sessions_hash" == "$repo_ce_sessions_hash" &&
     "$host_ce_test_browser_hash" == "$repo_ce_test_browser_hash" &&
     "$host_ce_test_xcode_hash" == "$repo_ce_test_xcode_hash" &&
     "$host_ce_setup_hash" == "$repo_ce_setup_hash" &&
     "$host_ce_worktree_hash" == "$repo_ce_worktree_hash" ]]
}

authority_gate_control_hash="$host_authority_gate_hash"
