skill_file_total="$(find "$ROOT_DIR/plugins/traceweaver-core/skills" -mindepth 2 -maxdepth 2 -name SKILL.md | wc -l | tr -d '[:space:]')"
anchored_skill_total="$(grep -Rsl '<!-- TRACEWEAVER: .*file-role=.*req=.*trace=.*ver=' "$ROOT_DIR/plugins/traceweaver-core/skills"/*/SKILL.md | wc -l | tr -d '[:space:]')"
imported_ce_unanchored_total=0
for ce_skill in "$ROOT_DIR"/plugins/traceweaver-core/skills/ce-*/SKILL.md; do
  if ! grep -q '<!-- TRACEWEAVER: .*file-role=.*req=.*trace=.*ver=' "$ce_skill"; then
    imported_ce_unanchored_total=$((imported_ce_unanchored_total + 1))
  fi
done
if [[ "$skill_file_total" != "47" ]]; then
  echo "traceweaver_skill_file_total=failed expected=47 actual=$skill_file_total" >&2
  exit 1
fi
if [[ "$anchored_skill_total" != "42" ]]; then
  echo "traceweaver_skill_file_anchored=failed expected=42 actual=$anchored_skill_total" >&2
  exit 1
fi
