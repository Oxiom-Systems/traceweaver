require_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "tw_skill_behavior_missing_required_file=$path" >&2
    exit 1
  fi
}

hash_file() {
  shasum -a 256 "$1" | awk '{print $1}'
}

line_number() {
  local pattern="$1"
  local path="$2"
  grep -n "$pattern" "$path" | head -n 1 | cut -d: -f1
}

assert_contains() {
  local path="$1"
  local pattern="$2"
  local label="$3"
  if ! grep -q -- "$pattern" "$path"; then
    echo "$label=failed_missing_pattern pattern=$pattern file=$path" >&2
    exit 1
  fi
}

assert_line_before() {
  local path="$1"
  local first="$2"
  local second="$3"
  local label="$4"
  local first_line second_line
  first_line="$(line_number "$first" "$path")"
  second_line="$(line_number "$second" "$path")"
  if [[ -z "$first_line" || -z "$second_line" || "$first_line" -ge "$second_line" ]]; then
    echo "$label=failed_order first=$first second=$second file=$path first_line=${first_line:-missing} second_line=${second_line:-missing}" >&2
    exit 1
  fi
}

assert_fixture_field() {
  local path="$1"
  local field="$2"
  local expected="$3"
  local label="$4"
  if ! grep -qx "$field=$expected" "$path"; then
    echo "$label=failed_fixture_field field=$field expected=$expected file=$path" >&2
    exit 1
  fi
}

