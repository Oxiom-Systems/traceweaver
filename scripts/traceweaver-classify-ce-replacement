  Generated JSON:
  `.traceweaver/ce-replacement-classification.generated.json`

  Runtime invocation, enforcement, publication, release-ready, clean-replacement,
  host CE removal, package-ready, upstream-ready, and R31 claims remain held.
  #{MARKER_END}
MARKDOWN

if options[:update_evidence]
  existing = read_text(options[:markdown_out])
  updated = if existing.include?(MARKER_BEGIN) && existing.include?(MARKER_END)
    existing.sub(/#{Regexp.escape(MARKER_BEGIN)}.*#{Regexp.escape(MARKER_END)}/m, markdown.strip)
  elsif existing.empty?
    markdown
  else
    "#{existing.rstrip}\n\n#{markdown}"
  end
  File.write(options[:markdown_out], updated.rstrip + "\n")
else
  FileUtils.mkdir_p(File.dirname(options[:markdown_out]))
  File.write(options[:markdown_out], markdown)
end

puts "checker_status=#{checker_status}"
puts "scope_mode=#{result[:scope_mode]}"
puts "packaged_traceweaver_skills=#{plugin_skill_names.size}"
puts "current_core_rows=#{current_core.size}"
puts "current_packaged_held_rows=#{current_held.size}"
puts "broad_held_rows=#{broad_rows.size}"
puts "out_of_scope_rows=#{out_of_scope_rows.size}"
puts "unclassified_rows=#{result[:counts][:unclassified_rows]}"
puts "json_out=#{options[:json_out]}"
puts "markdown_out=#{options[:markdown_out]}"
puts "held_claims=#{held_claims.join(",")}"
puts "errors=#{errors.empty? ? "none" : errors.join(";")}"

exit(errors.empty? ? 0 : 1)
